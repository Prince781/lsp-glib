#!/usr/bin/env bash

set -u

repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

vala_files=()
while IFS= read -r -d '' path; do
    vala_files+=("$path")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.vala')

if ((${#vala_files[@]} == 0)); then
    exit 0
fi

if ! command -v uncrustify >/dev/null 2>&1; then
    echo "pre-commit: uncrustify is required to check staged Vala files" >&2
    exit 1
fi

tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/lsp-glib-uncrustify.XXXXXX") || exit 1
trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

config="$tmp_dir/uncrustify.cfg"
if ! git cat-file blob :.uncrustify.cfg >"$config"; then
    echo "pre-commit: could not read .uncrustify.cfg from the index" >&2
    exit 1
fi

failed=0
for path in "${vala_files[@]}"; do
    original="$tmp_dir/original.vala"
    formatted="$tmp_dir/formatted.vala"

    if ! git cat-file blob ":$path" >"$original"; then
        printf 'pre-commit: could not read staged file %q\n' "$path" >&2
        failed=1
        continue
    fi

    if ! uncrustify -q -c "$config" -l VALA <"$original" >"$formatted"; then
        printf 'pre-commit: uncrustify failed for %q\n' "$path" >&2
        failed=1
        continue
    fi

    if ! cmp -s "$original" "$formatted"; then
        printf 'pre-commit: %q is not formatted\n' "$path" >&2
        failed=1
    fi
done

if ((failed != 0)); then
    cat >&2 <<'EOF'

Format the files above and stage the results:
  uncrustify -c .uncrustify.cfg -l VALA --replace --no-backup FILE...
EOF
fi

exit "$failed"
